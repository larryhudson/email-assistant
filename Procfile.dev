# Hivemind dev stack. Run with `make dev` (which also brings up Postgres).
#
# - web: FastAPI app — Mailgun webhook + admin UI at http://127.0.0.1:8001/admin/
# - worker: Procrastinate worker — picks up run_agent + curate_memory jobs.
#   Defaults to EMAIL_AGENT_WORKER_DRY_RUN=true so dev runs don't actually
#   send Mailgun replies. Drop the env var to send real mail.
web: uv run email-agent web --host 127.0.0.1 --port 8001
worker: EMAIL_AGENT_WORKER_DRY_RUN=true uv run email-agent worker
