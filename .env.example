# Postgres — matches docker-compose.yml. Note the +asyncpg driver suffix.
DATABASE_URL=postgresql+asyncpg://email_agent:devpassword@localhost:5432/email_agent

# Mailgun — webhook signing key, sending API key, and the sending domain.
# MAILGUN_WEBHOOK_URL is the public URL you've pointed Mailgun's inbound
# route at (e.g. the cloudflared quick-tunnel URL `make dev` prints).
MAILGUN_SIGNING_KEY=your-mailgun-webhook-signing-key
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.example.com
MAILGUN_WEBHOOK_URL=https://your-tunnel-or-prod-domain.example.com/webhooks/mailgun

# Admin UI — required when the FastAPI app mounts /admin behind a public tunnel.
ADMIN_BASIC_AUTH_USERNAME=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me

# Default agent model — Fireworks-hosted minimax-m2p7 via the OpenAI-
# compatible endpoint. Change FIREWORKS_MODEL_ID (env-overridable) to
# point at a different model on the same provider.
FIREWORKS_API_KEY=your-fireworks-api-key

# Cognee — durable memory layer. Defaults route Cognee's LLM calls through
# Fireworks (same key works for both vars; kept separate so you can swap
# providers without touching the agent's). Embedding key is OpenAI by
# default — Cognee's embedder is decoupled from the LLM.
COGNEE_LLM_API_KEY=your-fireworks-api-key
COGNEE_EMBEDDING_API_KEY=your-openai-api-key
